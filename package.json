{
  "name": "running-three",
  "version": "0.1.0",
  "description": "Highly encapsulated 3D toolkit with scene, model, event, camera, window, and highlight managers for industrial visualization and web dashboards",
  "type": "module",
  "main": "index.js",
  "types": "index.d.ts",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsup --config tsup.main.config.ts --watch",
    "build:worker": "tsup --config tsup.worker.config.ts",
    "prod:worker": "tsup --config tsup.worker.prod.config.ts",
    "build:main": "tsup --config tsup.main.config.ts",
    "prod:main": "tsup --config tsup.main.prod.config.ts",
    "build": "npm run build:worker && npm run build:main",
    "prod": "npm run prod:worker && npm run prod:main"
  },
  "keywords": [
    "babylonjs",
    "3d",
    "visualization",
    "toolkit",
    "dashboard",
    "digital-twin",
    "ui",
    "web-screen"
  ],
  "author": "JingXC",
  "license": "MIT",
  "devDependencies": {
    "cross-env": "^10.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@babylonjs/core": "8.18.0",
    "@babylonjs/gui": "8.18.0",
    "@babylonjs/loaders": "8.18.0",
    "@babylonjs/materials": "8.18.0",
    "@babylonjs/post-processes": "8.18.0",
    "@gltf-transform/core": "^4.3.0",
    "@gltf-transform/extensions": "^4.3.0",
    "gsap": "^3.13.0",
    "pixi.js": "^8.17.1",
    "zod": "^4.3.6"
  }
}
